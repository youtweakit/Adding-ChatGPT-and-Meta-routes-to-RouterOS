:global routeTable {
    { "subnet"="5.45.192.0/18"; "comment"="Yandex subnets" };
    { "subnet"="5.255.192.0/18"; "comment"="Yandex subnets" };
    { "subnet"="37.9.64.0/18"; "comment"="Yandex subnets" };
    { "subnet"="37.140.128.0/18"; "comment"="Yandex subnets" };
    { "subnet"="77.88.0.0/18"; "comment"="Yandex subnets" };
    { "subnet"="84.252.160.0/19"; "comment"="Yandex subnets" };
    { "subnet"="87.250.224.0/19"; "comment"="Yandex subnets" };
    { "subnet"="90.156.176.0/20"; "comment"="Yandex subnets" };
    { "subnet"="92.255.112.0/20"; "comment"="Yandex subnets" };
    { "subnet"="93.158.128.0/18"; "comment"="Yandex subnets" };
    { "subnet"="95.108.128.0/17"; "comment"="Yandex subnets" };
    { "subnet"="141.8.128.0/18"; "comment"="Yandex subnets" };
    { "subnet"="178.154.128.0/18"; "comment"="Yandex subnets" };
    { "subnet"="185.32.187.0/24"; "comment"="Yandex subnets" };
    { "subnet"="213.180.192.0/19"; "comment"="Yandex subnets" };
}

:foreach r in=$routeTable do={
    :local subnet ($r->"subnet")
    :local comment ($r->"comment")
    :local existing [/ip route find where dst-address=$subnet]
    :if ([:len $existing] > 0) do={ /ip route remove $existing }
    /ip route add dst-address=$subnet gateway=<YOUR GATEWAY HERE!!!> comment=$comment
}

:log info "Routes checked and added"
